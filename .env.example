# Kopiere diese Datei nach `.env` und trage echte Werte ein.
# Nur Werte mit Prefix EXPO_PUBLIC_ landen im App-Bundle — niemals Secrets hier ablegen!

# Supabase (EU-Region, eu-central-1)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server-seitig (NUR in Supabase Edge Function Secrets, nicht hier!) ---
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_SERVICE_ROLE_KEY=...
